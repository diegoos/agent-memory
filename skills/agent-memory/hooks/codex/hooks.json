{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_MEMORY_HOST=codex AGENT_MEMORY_EVENT=precompact .codex/hooks/agent-memory-flush.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_MEMORY_HOST=codex AGENT_MEMORY_EVENT=stop .codex/hooks/agent-memory-flush.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
